# Copy this file to .env (gitignored) and fill in your real keys.
# Never commit .env to git. Never paste API keys into chat / commits / public files.

# OpenAI (GPT-4, GPT-4o)
OPENAI_API_KEY=sk-...

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# DeepSeek (DeepSeek-V3 chat)
DEEPSEEK_API_KEY=sk-...

# Together.ai (Llama-3-70B and other open models)
TOGETHER_API_KEY=...
